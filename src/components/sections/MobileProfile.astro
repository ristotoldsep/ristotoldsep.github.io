---
import { socialLinks, type SiteCopy } from '../../i18n/site';

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
---
<div class="mobile-profile">
  <div class="mobile-profile-inner">
    <div class="mp-header">
      <img src="/aa_profile_pic.png" alt={copy.mobileProfile.photoAlt} class="mp-photo" loading="lazy">
      <div class="mp-identity">
        <span class="mp-name">Risto Tõldsep</span>
        <span class="mp-role">{copy.mobileProfile.role}</span>
        <span class="avail-status"><span class="avail-dot"></span>{copy.mobileProfile.availability}</span>
      </div>
    </div>
    <div class="mp-stats">
      {copy.mobileProfile.stats.map((stat) => (
        <div class="mp-stat">
          <span class="mp-stat-label">{stat.label}</span>
          <span class="mp-stat-value">{stat.value}</span>
        </div>
      ))}
    </div>
    <div class="mp-footer">
      <div class="mp-socials">
        {socialLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noopener" class="soc-btn" title={link.title}>
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" set:html={link.icon}></svg>
          </a>
        ))}
      </div>
      <a href="#contact" class="sidebar-cta">{copy.mobileProfile.cta}</a>
    </div>
  </div>
</div>
