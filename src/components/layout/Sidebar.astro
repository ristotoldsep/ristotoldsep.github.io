---
import { socialLinks, type SiteCopy } from '../../i18n/site';

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
---
<aside class="sidebar" id="sidebar" data-lenis-prevent>
  <div class="sidebar-inner" id="sidebarInner">

    <div class="sidebar-photo">
      <img src="/aa_profile_pic.png" alt={copy.sidebar.photoAlt}>
    </div>

    <div class="sidebar-name">
      <h1 class="sidebar-title">Risto<br>Tõldsep</h1>
      <p class="sidebar-role">{copy.sidebar.role}</p>
    </div>

    <div class="sidebar-data">
      {copy.sidebar.data.map((item, index) => (
        <div class="sidebar-data-item">
          <small>{item.label}</small>
          {index === copy.sidebar.data.length - 1 ? (
            <span class="avail-status"><span class="avail-dot"></span>{item.value}</span>
          ) : (
            <span>{item.value}</span>
          )}
        </div>
      ))}
    </div>

    <div class="sidebar-socials">
      {socialLinks.map((link) => (
        <a href={link.href} target="_blank" rel="noopener" class="soc-btn" title={link.title}>
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" set:html={link.icon}></svg>
        </a>
      ))}
    </div>

    <nav class="sidebar-nav" aria-label={copy.sidebar.navAriaLabel}>
      <a href="#home"    class="sidebar-nav-link">{copy.nav.links.home}</a>
      <a href="#work"    class="sidebar-nav-link">{copy.nav.links.work}</a>
      <a href="#about"   class="sidebar-nav-link">{copy.nav.links.about}</a>
      <a href="#skills"  class="sidebar-nav-link">{copy.nav.links.skills}</a>
      <a href="#contact" class="sidebar-nav-link">{copy.nav.links.contact}</a>
    </nav>

    <a href="#contact" class="sidebar-cta">{copy.sidebar.cta}</a>

  </div>
</aside>
