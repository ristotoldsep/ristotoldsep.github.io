---
import type { SiteCopy } from '../../i18n/site';

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
const switchHref = copy.locale === 'en' ? '/et/' : '/';
const flagClass = copy.locale === 'en' ? 'lang-switch-flag--et' : 'lang-switch-flag--en';
---
<nav class="topnav" id="topnav">
  <a href="#home" class="topnav-logo" aria-label={copy.nav.homeAriaLabel}>RT</a>
  <div class="topnav-nav">
    <span class="topnav-pill" id="topnavPill" aria-hidden="true"></span>
    <ul class="topnav-list" id="topnavList">
      <li><a href="#home"    class="topnav-link active">{copy.nav.links.home}</a></li>
      <li><a href="#work"    class="topnav-link">{copy.nav.links.work}</a></li>
      <li><a href="#about"   class="topnav-link">{copy.nav.links.about}</a></li>
      <li><a href="#skills"  class="topnav-link">{copy.nav.links.skills}</a></li>
      <li><a href="#contact" class="topnav-link">{copy.nav.links.contact}</a></li>
    </ul>
  </div>
  <div class="topnav-right">
    <a href={switchHref} class="lang-switch" aria-label={copy.meta.switchLanguageLabel}>
      <span class:list={['lang-switch-flag', flagClass]} aria-hidden="true"></span>
    </a>
    <a href="#contact" class="topnav-cv">{copy.nav.contactCta}</a>
    <button class="mobile-toggle" id="mobileToggle" aria-label={copy.nav.openMenuLabel}>
      <span></span><span></span>
    </button>
  </div>
</nav>
